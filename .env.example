# Environment variables for Product Catalog Automation Tool
# Copy this file to .env and fill in your values

# Description generation backend: "ollama" or "gemini"
DESCRIPTION_BACKEND=ollama

# Ollama settings (default backend)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llava

# Gemini API settings (alternative backend)
GEMINI_API_KEY=AIzaSyAelvIeT5vPN6P2gNZOAY-78cqnho23INI
GEMINI_MODEL=gemini-pro
GEMINI_API_URL=https://gemini.googleapis.com/v1/models

# Google Drive settings
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID_HERE